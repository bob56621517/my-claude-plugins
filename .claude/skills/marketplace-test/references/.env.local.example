# ═══════════════════════════════════════════════════
# marketplace-test 凭证模板
# 复制为项目根目录 .env.local 并填入实际值
# cp .claude/skills/marketplace-test/references/.env.local.example .env.local
# ═══════════════════════════════════════════════════

# ── 有默认值的变量（取消注释即可使用） ──

# BOCHA_API_KEY="<your-bocha-api-key>"
# GITHUB_PERSONAL_ACCESS_TOKEN="<your-github-token>"
# GITEE_ACCESS_TOKEN="<your-gitee-token>"
# GITLAB_PERSONAL_ACCESS_TOKEN="<your-gitlab-token>"
# GITLAB_API_URL="https://gitlab.example.com/api/v4"

# ── 无默认值的变量（必须自行填写） ──

# POSTGRES_DB_URL="postgresql://user:pass@localhost:5432/testdb"
# REDIS_URL="redis://localhost:6379"
# SQLITE_DB_PATH="/tmp/test-marketplace.db"
# FILESYSTEM_ALLOWED_DIR="/tmp/test-fs"
