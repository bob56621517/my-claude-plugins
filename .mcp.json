{
  "mcpServers": {
    "wikidata": {
      "type": "http",
      "url": "https://wd-mcp.wmcloud.org/mcp/"
    },
    "bocha-search": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-bocha-search"
      ],
      "env": {
        "BOCHA_API_KEY": "${BOCHA_API_KEY}"
      }
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "bunx",
      "args": [
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "github": {
      "type": "stdio",
      "command": "github-mcp-server",
      "args": [
        "stdio"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
  }
}